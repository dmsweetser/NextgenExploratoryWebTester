# Local Model Configuration
USE_LOCAL_MODEL=true
MODEL_PATH=models/your_model.gguf
MODEL_CONTEXT=131072
MODEL_THREADS=4
MODEL_BATCH=512
MODEL_GPU_LAYERS=0

# Azure Foundry Configuration (only used if USE_LOCAL_MODEL=false)
AZURE_ENDPOINT=https://your-resource.azure.ai
AZURE_API_KEY=your-api-key
AZURE_MODEL_NAME=model-name

# Model Parameters
OUTPUT_TOKENS=32768
TEMPERATURE=0.9
TOP_P=0.8
TOP_K=20
MIN_P=0.0

# Email Notifications
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your-email@yourprovider.com
SMTP_PASSWORD=your-password
SMTP_FROM=bot@yourdomain.com
BUG_NOTIFICATION_EMAILS=team1@company.com,team2@company.com

# Security
ALLOWED_ORIGINS=*
DEBUG=false

# Selenium behaviors
HEADLESS=true
DEFAULT_WAIT=10
