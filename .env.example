# NEWT Configuration

# LLM Configuration
USE_LOCAL_MODEL=true
MODEL_PATH=models/llama-2-7b-chat.gguf
MODEL_CONTEXT=131072
MODEL_THREADS=4
MODEL_BATCH=512
MODEL_GPU_LAYERS=0

# Azure AI Configuration (if not using local model)
# USE_LOCAL_MODEL=false
# AZURE_ENDPOINT=https://your-resource.azure.ai
# AZURE_API_KEY=your-api-key
# AZURE_MODEL_NAME=gpt-35-turbo

# Model Parameters
OUTPUT_TOKENS=32768
TEMPERATURE=0.9
TOP_P=0.8
TOP_K=20
MIN_P=0.0

# Email Notifications
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your-email@yourprovider.com
SMTP_PASSWORD=your-password
SMTP_FROM=newt@yourdomain.com
BUG_NOTIFICATION_EMAILS=team1@company.com,team2@company.com

# Application Settings
DEBUG=false
HEADLESS=true
LOG_PROMPTS=true
DEFAULT_WAIT=10
MAX_FAILURES=100
ALLOW_CONCLUDE=true
